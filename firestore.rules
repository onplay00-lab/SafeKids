rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // 헬퍼 함수
    // ============================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isFamilyMember(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId)).data;
      return isSignedIn() && (
        request.auth.uid in family.parentIds ||
        request.auth.uid in family.children
      );
    }

    function isFamilyParent(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId)).data;
      return isSignedIn() && request.auth.uid in family.parentIds;
    }

    // ============================================
    // users/{uid}
    // ============================================
    match /users/{uid} {
      // 본인만 읽기/쓰기, 같은 가족이면 읽기 허용
      allow read: if isOwner(uid) || (
        isSignedIn() &&
        resource.data.familyId != null &&
        isFamilyMember(resource.data.familyId)
      );
      allow create: if isOwner(uid);
      // 본인 또는 같은 가족의 부모가 업데이트 가능 (이름 변경 등)
      allow update: if isOwner(uid) || (
        isSignedIn() &&
        resource.data.familyId != null &&
        isFamilyParent(resource.data.familyId)
      );
      allow delete: if false;
    }

    // ============================================
    // families/{familyId}
    // ============================================
    match /families/{familyId} {
      // 가족 구성원 읽기 + 로그인 사용자 초대코드 조회 허용
      allow read: if isSignedIn();
      // 부모만 생성 (familyId == 본인 uid)
      allow create: if isSignedIn() && familyId == request.auth.uid;
      // 가족 구성원이면 업데이트, 또는 초대코드로 참여 시 (children/parentIds에 자기 uid 추가)
      allow update: if isSignedIn() && (
        isFamilyMember(familyId) ||
        // 초대코드로 가족 참여: children 또는 parentIds에 본인 추가만 허용
        (resource.data.inviteCode != null)
      );
      allow delete: if false;

      // --- locations ---
      match /locations/{childUid} {
        allow read: if isFamilyMember(familyId);
        allow write: if isOwner(childUid) && isFamilyMember(familyId);
      }

      // --- screentime ---
      match /screentime/{childUid} {
        allow read: if isFamilyMember(familyId);
        // 자녀 본인이 사용시간 기록, 부모가 제한 설정
        allow write: if isFamilyMember(familyId) && (
          isOwner(childUid) || isFamilyParent(familyId)
        );
      }

      // --- geofences ---
      match /geofences/{geofenceId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyParent(familyId);
      }

      // --- geofenceStatus ---
      match /geofenceStatus/{childUid} {
        allow read: if isFamilyMember(familyId);
        allow write: if isOwner(childUid) && isFamilyMember(familyId);
      }

      // --- geofenceAlerts ---
      match /geofenceAlerts/{alertId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyParent(familyId);
      }

      // --- sos ---
      match /sos/{sosId} {
        allow read: if isFamilyMember(familyId);
        // 자녀만 SOS 생성
        allow create: if isSignedIn() && isFamilyMember(familyId);
        // 부모만 resolved 처리
        allow update: if isFamilyParent(familyId);
        allow delete: if false;
      }

      // --- promises ---
      match /promises/{promiseId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyParent(familyId);
      }

      // --- promiseChecks ---
      match /promiseChecks/{checkId} {
        allow read: if isFamilyMember(familyId);
        // 자녀 본인만 체크/체크해제
        allow write: if isSignedIn() && isFamilyMember(familyId);
      }

      // --- timeRequests ---
      match /timeRequests/{requestId} {
        allow read: if isFamilyMember(familyId);
        // 자녀가 요청 생성
        allow create: if isSignedIn() && isFamilyMember(familyId);
        // 부모가 승인/거절
        allow update: if isFamilyParent(familyId);
        allow delete: if false;
      }

      // --- chat ---
      match /chat/{messageId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isSignedIn() && isFamilyMember(familyId);
        allow update, delete: if false;
      }

      // --- loudSignals ---
      match /loudSignals/{signalId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyParent(familyId);
        allow update, delete: if false;
      }

      // --- appBlocking ---
      match /appBlocking/{childUid} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyParent(familyId);
      }

      // --- emotionChecks ---
      match /emotionChecks/{checkId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isSignedIn() && isFamilyMember(familyId);
        allow update, delete: if false;
      }

      // --- presence ---
      match /presence/{uid} {
        allow read: if isFamilyMember(familyId);
        allow write: if isOwner(uid) && isFamilyMember(familyId);
      }

      // --- screentimeHistory ---
      match /screentimeHistory/{childUid}/{document=**} {
        allow read: if isFamilyMember(familyId);
        allow write: if isOwner(childUid) && isFamilyMember(familyId);
      }

      // --- soundRequests ---
      match /soundRequests/{requestId} {
        allow read: if isFamilyMember(familyId);
        // 부모가 요청 생성
        allow create: if isFamilyParent(familyId);
        // 자녀가 녹음 결과 업데이트 (completed/failed), 부모도 업데이트 가능
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyParent(familyId);
      }

      // --- behaviorAlerts ---
      match /behaviorAlerts/{alertId} {
        allow read: if isFamilyMember(familyId);
        // Cloud Functions에서 생성하므로 클라이언트에선 읽기/업데이트만
        allow create: if isFamilyMember(familyId);
        // 부모가 읽음 처리
        allow update: if isFamilyParent(familyId);
        allow delete: if isFamilyParent(familyId);
      }
    }

    // 나머지 모든 문서 접근 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
